{
  "extends": "@tsconfig/next-strictest/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "downlevelIteration": true,
    "paths": {
      "~*": ["./*"]
    }
  },
  "exclude": ["node_modules"],
  "include": ["next-env.d.ts", "env.d.ts", "**/*.d.ts", "**/*.js", "**/*.json", "**/*.jsx", "**/*.ts", "**/*.tsx"]
}

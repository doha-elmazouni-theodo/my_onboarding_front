{
  "name": "nw-nextjs-boilerplate",
  "private": true,
  "engines": {
    "pnpm": "~8",
    "node": ">=16.14"
  },
  "scripts": {
    "dev": "pnpm check-filesize && next dev",
    "build": "next build --no-lint",
    "build:export": "next build --no-lint && next export",
    "start": "next start",
    "lint": "next lint --ignore-path .gitignore --dir .",
    "lint:fix": "yarn lint --fix --ext .ts,.tsx,.js,.jsx",
    "commit": "git cz",
    "test": "jest",
    "test:snap": "jest --maxWorkers=50% --silent --watchAll=false --testMatch='!**/*' --testMatch='**/*.snap.tsx'",
    "test:coverage": "jest --coverage --maxWorkers=50% --silent --watchAll=false --reporters=default --coverageReporters=cobertura --coverageReporters=text-summary --coverageReporters=json-summary --coverageReporters=lcov --testMatch='**/*.{spec,test}.{js,jsx,ts,tsx}'",
    "generate": "plop",
    "preinstall": "npx -y only-allow pnpm",
    "prepare": "next telemetry disable && husky install",
    "check-filesize": "node .ci/scripts/check-filesize.js"
  },
  "dependencies": {
    "@emotion/cache": "^11.10.5",
    "@emotion/react": "^11.10.5",
    "@emotion/server": "^11.10.0",
    "@emotion/styled": "^11.10.5",
    "@reduxjs/toolkit": "^1.9.2",
    "jest-junit": "^15.0.0",
    "next": "13.1.6",
    "next-seo": "^5.15.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "^8.0.5"
  },
  "prettier": {
    "endOfLine": "lf",
    "printWidth": 120,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@emotion/jest": "^11.10.5",
    "@nimbleways/eslint-config": "^0.2.5",
    "@testing-library/dom": "^8.20.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@tsconfig/next-strictest": "^1.0.1",
    "@types/eslint": "^8.4.10",
    "@types/jest": "^29.4.0",
    "@types/node": "18.11.18",
    "@types/react": "18.0.27",
    "@types/react-redux": "^7.1.25",
    "autoprefixer": "^10.4.13",
    "commitizen": "^4.3.0",
    "eslint": "^8.33.0",
    "eslint-config-next": "13.1.6",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "git-cz": "^4.9.0",
    "husky": "^8.0.3",
    "jest": "^29.4.1",
    "jest-environment-jsdom": "^29.4.1",
    "lint-staged": "^13.1.0",
    "next-http-proxy-middleware": "^1.2.5",
    "plop": "^3.1.1",
    "postcss": "^8.4.21",
    "prettier": "^2.8.3",
    "tailwindcss": "^3.2.4",
    "ts-jest": "^29.0.5",
    "typescript": "4.9.5",
    "glob-all": "^3.3.1"
  }
}
